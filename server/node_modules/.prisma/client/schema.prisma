generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id                 String           @id @default(cuid())
  title              String
  address            String
  initialDescription String           @map("initial_description")
  fullDescription    String           @map("full_description")
  status             JobStatus        @default(PENDING)
  hirerId            String           @map("hirer_id")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  payments           Payment[]
  jobImages          JobImage[]
  applications       JobApplication[]

  @@map("jobs")
}

model Payment {
  id              String        @id @default(cuid())
  amount          Float
  platformFee     Float?
  workerAmount    Float?
  depositRefund   Float?
  status          PaymentStatus @default(PENDING)
  hirerId         String        @map("hirer_id")
  workerId        String        @map("worker_id")
  jobId           String        @map("job_id")
  job             Job           @relation(fields: [jobId], references: [id])
  stripePaymentId String?       @map("stripe_payment_id")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payments")
}

model JobApplication {
  id            String            @id @default(cuid())
  jobId         String
  job           Job               @relation(fields: [jobId], references: [id])
  workerId      String            @map("worker_id")
  worker        Worker            @relation(fields: [workerId], references: [id])
  message       String?
  status        ApplicationStatus @default(APPLIED)
  depositId     String?           @map("deposit_id")
  depositStatus DepositStatus     @default(AUTHORIZED)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("job_applications")
}

model Worker {
  id           String           @id @default(cuid())
  userId       String           @unique
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications JobApplication[]

  @@map("workers")
}

model JobImage {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  url       String
  isPublic  Boolean  @default(false)
  caption   String?
  createdAt DateTime @default(now())

  @@map("job_images")
}

enum DepositStatus {
  AUTHORIZED
  CAPTURED
  REFUNDED
}

enum JobStatus {
  PENDING
  COMMITTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  APPLIED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}
