generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id                String        @id @default(cuid())
  title             String
  address           String
  initialDescription String       @map("initial_description")
  fullDescription    String       @map("full_description")
  status            JobStatus     @default(PENDING)
  
  generalLocation   String?       @map("general_location")
  city              String?
  state             String?

  price              Int
  estimatedTime      Int?          @map("estimated_time") // In minutes

  hirerId           String        @map("hirer_id")
  createdAt         DateTime      @default(now()) @map("createdAt")
  updatedAt         DateTime      @updatedAt @map("updatedAt")
  payments          Payment[]
  jobImages         JobImage[]
  applications      JobApplication[]
  messages          Message[]
  @@map("jobs")
}
model Payment {
  id            String         @id @default(cuid())
  amount        Float          // Total amount charged to hirer
  platformFee   Float          // 10% fee kept by platform (required)
  workerAmount  Float          // 90% sent to worker (required)
  depositRefund Float?         // $5 deposit refund amount
  status        PaymentStatus  @default(PENDING)
  hirerId       String         @map("hirer_id")   // Supabase user ID
  workerId      String         @map("worker_id")  // Supabase user ID
  jobId         String         @map("job_id")
  job           Job            @relation(fields: [jobId], references: [id])
  stripePaymentId  String?        @map("stripe_payment_id")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  @@map("payments")
}

model StripeAccount {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  accountId         String   @unique @map("account_id")
  chargesEnabled    Boolean  @default(false) @map("charges_enabled")
  payoutsEnabled    Boolean  @default(false) @map("payouts_enabled")
  detailsSubmitted  Boolean  @default(false) @map("details_submitted")
  requiresAction    Boolean  @default(false) @map("requires_action")
  currentDeadline   DateTime? @map("current_deadline")
  lastSyncAt        DateTime? @map("last_sync_at")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@map("stripe_accounts")
}

model JobApplication {
  id            String         @id @default(cuid())
  jobId         String
  job           Job            @relation(fields: [jobId], references: [id])
  workerId      String         @map("worker_id")  // This is the Supabase user ID
  message       String?
  status        ApplicationStatus @default(APPLIED)
  depositId     String?        @map("deposit_id")
  depositStatus DepositStatus  @default(AUTHORIZED)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  @@map("job_applications")
}

model JobImage {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  url       String
  isPublic  Boolean  @default(false)  // Controls visibility before deposit
  caption   String?
  createdAt DateTime @default(now())
  @@map("job_images")
}

model Message {
  id             String   @id @default(cuid())
  content        String
  senderId       String   @map("sender_id")    // Supabase user ID
  receiverId     String   @map("receiver_id")  // Supabase user ID
  jobId          String?  @map("job_id")       // Optional: link to specific job
  job            Job?     @relation(fields: [jobId], references: [id])
  conversationId String   @map("conversation_id") // Group messages into conversations
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@map("messages")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("user_profiles")
}

enum DepositStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
}

enum JobStatus {
  PENDING
  COMMITTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  APPLIED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}